# LLM API (OpenAI or any OpenAI-compatible API)
# --- Option A: OpenAI (default in this example) ---
# https://platform.openai.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# --- Option B: Alibaba Bailian (qwen-plus) ---
# Uncomment and set these if you use Bailian instead; comment out Option A above.
# https://bailian.console.aliyun.com/
# LLM_API_KEY=your_bailian_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus

# ===== Graph backend (choose one) =====
# Option: zep (Zep Cloud) or neo4j
GRAPH_BACKEND=zep

# --- When GRAPH_BACKEND=zep (default) ---
# Free tier: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# --- When GRAPH_BACKEND=neo4j ---
# Uncomment and set these; comment out ZEP_API_KEY above.
# With docker-compose.neo4j.yml (auth off): no password needed on Neo4j, use NEO4J_PASSWORD=neo4j so the app can connect.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4j

# ===== Optional: accelerated LLM =====
# Omit these keys from .env if you are not using an accelerated LLM
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
